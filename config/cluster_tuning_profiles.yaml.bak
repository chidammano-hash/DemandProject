# ═══════════════════════════════════════════════════════════════════════════════
# PER-CLUSTER HYPERPARAMETER PROFILES
# ═══════════════════════════════════════════════════════════════════════════════
# Overrides LGBM base params (from forecast_pipeline_config.yaml) on a
# per-cluster basis. Each cluster can have its own tuned hyperparameters.
#
# Generated by: make tune-lgbm-clusters
#   (runs scripts/tune_cluster_hyperparams.py --model lgbm --trials 30)
#
# How matching works (two phases in resolve_cluster_params):
#   Phase 1: Exact cluster_name match — if a profile has
#            match_criteria.cluster_name == ml_cluster value, use it.
#   Phase 2: Demand-stats match — if no name match, fall back to matching
#            by mean_demand, cv_demand, zero_demand_pct, etc.
#   Default: If neither matches, base params from forecast_pipeline_config.yaml
#            are used and the log shows "using global params (no profile match)".
#
# Overrides are MERGED onto base params — only keys listed in "overrides"
# are changed; unlisted keys keep their base values.
#
# To disable all profiles and use global params everywhere:
#   enabled: false
#
# To re-tune: make tune-lgbm-clusters
#   (backs up this file to .yaml.bak before overwriting)
# ═══════════════════════════════════════════════════════════════════════════════

# Auto-generated by scripts/tune_cluster_hyperparams.py
# Generated: 2026-04-07T21:22:42
# Model: lgbm

cluster_profiles:

  # ── L2_1: High-volume stable demand ──────────────────────────────────────
  # 489 DFUs, 17,115 training rows
  # Tuned params: slower LR (0.011), moderate leaves (76), depth 7
  L2_1:
    description: "Auto-tuned (17115 rows, WAPE=inf%)"
    match_criteria:
      cluster_name: L2_1              # Phase 1 exact match on dim_sku.ml_cluster
    overrides:
      learning_rate: 0.01145589568679892
      num_leaves: 76
      max_depth: 7
      min_child_samples: 76           # High — prevents overfitting on stable demand
      subsample: 0.9594455689966863
      colsample_bytree: 0.7163097473045985
      feature_fraction_bynode: 0.7177519234544782
      path_smooth: 2.172296700223026  # Moderate smoothing
      reg_alpha: 1.0820069105894676   # Strong L1 — promotes feature sparsity
      reg_lambda: 1.8854016405604005e-07  # Near-zero L2
      min_gain_to_split: 3.417795076005652  # High — conservative splits
      n_estimators: 550

  # ── L2_1S: Seasonal variant of L2_1 ─────────────────────────────────────
