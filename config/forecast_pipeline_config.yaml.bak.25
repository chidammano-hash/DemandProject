# ═══════════════════════════════════════════════════════════════════════════════
# FORECAST PIPELINE MASTER CONFIG
# ═══════════════════════════════════════════════════════════════════════════════
# Single source of truth for the ML forecast pipeline. Controls algorithm
# roster, backtest settings, hyperparameter tuning, champion selection,
# production forecast generation, and pipeline orchestration.
#
# Load via: load_forecast_pipeline_config() from common/utils.py
# ═══════════════════════════════════════════════════════════════════════════════

# ─── ALGORITHM ROSTER ─────────────────────────────────────────────────────────
# Each algorithm has lifecycle flags controlling which pipeline stages it
# participates in:
#   enabled  : master switch — disabled algorithms are skipped everywhere
#   tune     : include in hyperparameter tuning (make tune-lgbm, tune-lgbm-clusters)
#   backtest : include in expanding-window backtesting (make backtest-lgbm)
#   compete  : include in champion model selection (make champion-all)
#   forecast : use for production forecast generation (make forecast-generate)
#   expert   : include in expert panel algorithm comparison
#
# cluster_strategy:
#   "per_cluster" — trains one model per ml_cluster (from dim_sku)
#   "global"      — trains one model on all data with ml_cluster as a feature
#
# output_dir: where backtest CSVs and model artifacts are saved

algorithms:

  # ── Tree-based models (gradient boosting) ─────────────────────────────────

  lgbm_cluster:
    type: tree
    enabled: true
    tune: true
    backtest: true
    compete: true
    forecast: true                    # Used for production forecast generation
    expert: false
    cluster_strategy: per_cluster     # One LGBM model per cluster
    output_dir: data/backtest/lgbm_cluster
    params:
      # --- Prediction mode ---
      recursive: true                 # true=multi-step recursive (predict month 1, feed as lag for month 2, ...)
                                      # false=direct multi-output (predict all months at once)

      # --- Feature selection (SHAP pipeline) ---
      shap_select: true               # Enable 4-stage feature selection (see spec 23)
      shap_threshold: 0.9             # Cumulative SHAP importance cutoff (0.90 = keep features covering 90% of importance)
      shap_top_n: null                # If set, keep exactly this many features (overrides threshold)
      shap_sample_size: 500           # Max rows sampled per cluster for SHAP computation
      correlation_filter: false       # Stage 2: remove highly correlated features before SHAP
      correlation_threshold: 0.98     # Pearson correlation cutoff (only used if correlation_filter=true)
      variance_filter: false          # Stage 1: remove near-zero variance features before SHAP
      variance_threshold: 0.01        # Relative variance cutoff (only used if variance_filter=true)

      # --- Inline tuning ---
      tune_inline: false              # true=run mini Bayesian tuning per timeframe during backtest (~2 min/timeframe)
                                      # false=use static params below (or from cluster_tuning_profiles.yaml)
      params_file: null               # Optional: load params from a JSON file instead of below

      # --- LightGBM hyperparameters ---
      objective: regression_l1        # Loss function: regression_l1 (MAE), regression (MSE), huber, quantile, tweedie
                                      # MAE is best for demand data — robust to outliers, slight under-forecast bias
      n_estimators: 2000              # Max boosting rounds (early stopping may stop sooner)
      learning_rate: 0.015            # Step size shrinkage — lower = more rounds needed but more stable
      num_leaves: 63                  # Max leaves per tree — controls model complexity (default overridden by cluster profiles)
      min_child_samples: 20           # Min rows per leaf — prevents overfitting on small groups
      max_depth: 8                    # Max tree depth — -1 for unlimited (bounded by num_leaves)
      min_gain_to_split: 0.01         # Min loss reduction to make a split — higher = more conservative
      subsample: 0.75                 # Row sampling ratio per tree (0.75 = use 75% of rows)
      bagging_freq: 1                 # How often to subsample (1 = every iteration)
      colsample_bytree: 0.8           # Feature sampling ratio per tree
      feature_fraction_bynode: 0.8    # Feature sampling ratio per split node
      reg_lambda: 0.8                 # L2 regularization — penalizes large leaf values
      reg_alpha: 0.1                  # L1 regularization — promotes feature sparsity
      path_smooth: 0.5               # Smooths leaf values toward parent mean — higher = more smoothing
      max_bin: 255                    # Histogram bins for continuous features — 255 is LGBM default

  catboost_cluster:
    type: tree
    enabled: false
    tune: true
    backtest: true
    compete: true
    forecast: true
    expert: false
    cluster_strategy: per_cluster
    output_dir: data/backtest/catboost_cluster
    params:
      recursive: true
      shap_select: true
      shap_threshold: 0.95
      shap_top_n: null
      shap_sample_size: 500
      correlation_filter: true
      correlation_threshold: 0.95
      variance_filter: true
      variance_threshold: 0.01
      tune_inline: false
      params_file: null
      iterations: 800                 # CatBoost equivalent of n_estimators
      learning_rate: 0.03
      depth: 7                        # CatBoost equivalent of max_depth
      l2_leaf_reg: 7.5                # CatBoost L2 regularization
      subsample: 0.85
      grow_policy: Lossguide          # Leaf-wise growth (like LGBM)
      border_count: 32                # CatBoost equivalent of max_bin
      random_strength: 0.4            # Random noise added to feature scores
      min_data_in_leaf: 28            # CatBoost equivalent of min_child_samples
      colsample_bylevel: 0.85         # Feature sampling per tree level
      bagging_temperature: 0.4        # Controls bootstrap aggressiveness
      max_leaves: 80
      bootstrap_type: MVS             # Minimum Variance Sampling — faster than Bayesian
      model_size_reg: 0.1             # Penalty for large models
      score_function: L2
      boost_from_average: true        # Initialize with mean target — speeds convergence
      leaf_estimation_method: Newton
      leaf_estimation_iterations: 1
      max_ctr_complexity: 1           # Max feature combinations for categorical target stats

  xgboost_cluster:
    type: tree
    enabled: false
    tune: true
    backtest: true
    compete: true
    forecast: true
    expert: false
    cluster_strategy: per_cluster
    output_dir: data/backtest/xgboost_cluster
    params:
      recursive: true
      shap_select: true
      shap_threshold: 0.95
      shap_top_n: null
      shap_sample_size: 500
      correlation_filter: true
      correlation_threshold: 0.95
      variance_filter: true
      variance_threshold: 0.01
      tune_inline: false
      params_file: null
      n_estimators: 2000
      learning_rate: 0.02
      max_depth: 7
      min_child_weight: 15            # XGBoost equivalent of min_child_samples
      subsample: 0.8
      colsample_bytree: 0.8
      grow_policy: lossguide
      max_leaves: 255
      max_bin: 256
      reg_lambda: 5.0
      reg_alpha: 0.5
      gamma: 0.1                      # XGBoost equivalent of min_gain_to_split
      colsample_bylevel: 0.8
      booster: gbtree

  # ── Customer-enriched tree models (same algos + customer demand features) ──

  lgbm_cust_enriched:
    type: tree
    enabled: false
    tune: true
    backtest: true
    compete: true
    forecast: true
    expert: false
    cluster_strategy: per_cluster
    output_dir: data/backtest/lgbm_cust_enriched
    params:
      recursive: true
      shap_select: true
      shap_threshold: 0.95
      shap_sample_size: 500
      correlation_filter: true
      correlation_threshold: 0.95
      variance_filter: true
      variance_threshold: 0.01
      customer_features: true         # Merge customer concentration/dynamics features from customer_features_monthly
      objective: regression_l1
      n_estimators: 1500
      learning_rate: 0.02
      num_leaves: 63
      min_child_samples: 20
      max_depth: 8
      min_gain_to_split: 0.005
      subsample: 0.7
      bagging_freq: 1
      colsample_bytree: 0.75
      feature_fraction_bynode: 0.6
      reg_lambda: 1.5
      reg_alpha: 0.15
      path_smooth: 1.0
      max_bin: 255

  catboost_cust_enriched:
    type: tree
    enabled: false
    tune: true
    backtest: true
    compete: true
    forecast: true
    expert: false
    cluster_strategy: per_cluster
    output_dir: data/backtest/catboost_cust_enriched
    params:
      recursive: true
      shap_select: true
      shap_threshold: 0.95
      shap_sample_size: 500
      correlation_filter: true
      correlation_threshold: 0.95
      variance_filter: true
      variance_threshold: 0.01
      customer_features: true
      iterations: 800
      learning_rate: 0.03
      depth: 7
      l2_leaf_reg: 9.0
      subsample: 0.85
      grow_policy: Lossguide
      border_count: 32
      random_strength: 0.4
      min_data_in_leaf: 28
      colsample_bylevel: 0.8
      bagging_temperature: 0.4
      max_leaves: 80
      bootstrap_type: MVS
      model_size_reg: 0.1
      score_function: L2
      boost_from_average: true

  xgboost_cust_enriched:
    type: tree
    enabled: false
    tune: true
    backtest: true
    compete: true
    forecast: true
    expert: false
    cluster_strategy: per_cluster
    output_dir: data/backtest/xgboost_cust_enriched
    params:
      recursive: true
      shap_select: true
      shap_threshold: 0.95
      shap_sample_size: 500
      correlation_filter: true
      correlation_threshold: 0.95
      variance_filter: true
      variance_threshold: 0.01
      customer_features: true
      n_estimators: 2000
      learning_rate: 0.02
      max_depth: 7
      min_child_weight: 15
      subsample: 0.8
      colsample_bytree: 0.75
      grow_policy: lossguide
      max_leaves: 255
      max_bin: 256
      reg_lambda: 6.0
      reg_alpha: 0.6
      gamma: 0.1
      colsample_bylevel: 0.75
      booster: gbtree

  # ── Foundation models (pretrained, zero-shot or fine-tuned) ────────────────

  chronos:
    type: foundation
    enabled: false
    tune: false                       # Foundation models are not tuned — pretrained weights
    backtest: true
    compete: false
    forecast: false
    expert: true
    output_dir: data/backtest/chronos
    params:
      model_size: small               # small (46M), base (200M), large (710M)
      device: auto                    # auto, cpu, cuda, mps
      batch_size: 1024                # DFUs processed in parallel
      num_samples: 20                 # Monte Carlo samples for probabilistic forecast
      prediction_length: 6            # Months to predict
      num_workers: 1                  # DataLoader workers

  chronos_bolt:
    type: foundation
    enabled: true
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: false
    output_dir: data/backtest/chronos_bolt
    params:
      model_size: base                # Bolt is faster than Chronos T5 (~12 min vs ~2.5h)
      device: auto
      batch_size: 512
      num_samples: 12
      prediction_length: 6
      num_workers: 1

  chronos2:
    type: foundation
    enabled: false
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: false
    output_dir: data/backtest/chronos2
    params:
      device: auto
      batch_size: 2048
      prediction_length: 6
      num_workers: 1

  chronos2_enriched:
    type: foundation
    enabled: true
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: false
    output_dir: data/backtest/chronos2_enriched
    params:
      device: auto
      batch_size: 1024
      prediction_length: 6
      num_workers: 1
      # Uses past_covariates (lag/rolling/TS profile features) and
      # future_covariates (calendar/Fourier) from build_feature_matrix.
      # Customer features merged when customer_features_monthly is populated.

  bolt_hierarchical:
    type: foundation
    enabled: false
    tune: false
    backtest: true
    compete: true
    forecast: true
    expert: false
    output_dir: data/backtest/bolt_hierarchical
    notes: Customer-level bottom-up Bolt + top-down reconciliation using true demand
    params:
      model_size: base
      device: auto
      batch_size: 2048
      prediction_length: 6
      n_timeframes: 10
      bu_chunk_size: 200000           # Rows per chunk for bottom-up forecasting
      min_nonzero_months: 6           # Min non-zero months to include a customer-item pair
      min_history_months: 6
      max_customers_per_item_loc: 100 # Cap customer count per item-location
      reconciliation_method: weighted_average  # How to blend bottom-up and top-down
      bu_weight: 0.6                  # Weight for bottom-up (0.6 = 60% bottom-up, 40% top-down)

  # ── Statistical models ────────────────────────────────────────────────────

  mstl:
    type: statistical
    enabled: true
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: true
    output_dir: data/backtest/mstl
    params:
      season_length: 12               # Seasonal period in months
      min_history: 25                  # Min months of history required

  # ── Deep learning models ──────────────────────────────────────────────────

  nbeats:
    type: deep_learning
    enabled: true
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: true
    output_dir: data/backtest/nbeats
    params:
      h: 6                            # Forecast horizon (months)
      input_size: 24                  # Lookback window (months of history as input)
      max_steps: 500                  # Training epochs
      batch_size: 32
      learning_rate: 0.001
      scaler_type: standard           # Normalize input (standard, robust, minmax)
      early_stop_patience_steps: -1   # -1 = no early stopping

  nhits:
    type: deep_learning
    enabled: true
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: false
    output_dir: data/backtest/nhits
    params:
      h: 6
      input_size: 24
      max_steps: 500
      batch_size: 32
      learning_rate: 0.001
      scaler_type: standard
      early_stop_patience_steps: -1

  # ── Baseline models (simple statistical, no ML) ───────────────────────────

  seasonal_naive:
    type: statistical
    enabled: true
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: false
    cluster_strategy: per_cluster
    output_dir: data/backtest/seasonal_naive
    params: {}                        # Uses same-month-last-year as prediction

  rolling_mean:
    type: statistical
    enabled: false
    tune: false
    backtest: true
    compete: true
    forecast: false
    expert: true
    cluster_strategy: per_cluster
    output_dir: data/backtest/rolling_mean
    params:
      window: 6                       # Rolling window size in months


# ─── BACKTEST SETTINGS ────────────────────────────────────────────────────────
# Controls the expanding-window backtesting framework used by all algorithms.

backtest:
  n_timeframes: 10                    # Number of expanding windows (A-J). More = more robust but slower.
  embargo_months: 0                   # Gap between train_end and predict_start. 0=predict starts 1 month after training.
                                      # 2=simulates real-world delay (data processing + forecast generation time).
  forecast_horizon: 6                 # Months to predict per timeframe
  early_stop_pct: 0.05               # Early stopping patience as % of n_estimators (0.05 = 5% = 100 rounds at 2000 est.)
                                      # Sparse clusters automatically get 10% (SPARSE_EARLY_STOP_PCT in model_registry.py)
  shap_retrain_threshold: 0.5        # Min feature drop % to trigger SHAP retrain (0.5 = only retrain if 50%+ features dropped)
                                      # Set high because retrain rarely improves over original model.
  shap_min_features: 20              # Min features to keep after SHAP selection (floor)
  n_seeds: 1                         # Number of random seeds to run (>1 = variance estimation, slower)
  tweedie_variance_power: 1.5        # Tweedie distribution parameter (1=Poisson, 2=Gamma). Used when objective=tweedie.
  intermittent_threshold: 0.7        # Zero-demand % above which cluster is classified as "intermittent"
                                      # Intermittent clusters are routed to seasonal naive baseline instead of LGBM.
  lumpy_threshold: 0.3               # Zero-demand % above which cluster is "lumpy" (between lumpy_threshold and intermittent_threshold)
  output_dir: data/backtest           # Base output directory for all backtest results
  recursive_noise_enabled: true       # Add noise to lag features during training to improve robustness for recursive mode
  recursive_noise_pct: 0.05          # Noise magnitude (0.05 = 5% of lag value). Simulates prediction errors the model
                                      # will see during recursive inference where its own predictions become lag inputs.
  recursive_lag_smooth: 0.15         # Lag smoothing factor for recursive steps 3+ (0.15 = blend 85% prediction + 15% previous lag).
                                      # Reduces error amplification in the recursive chain. 0 = disabled.


# ─── HYPERPARAMETER TUNING ────────────────────────────────────────────────────
# Controls Bayesian optimization (Optuna) for tree model hyperparameters.
# Global tuning: make tune-lgbm (tunes one set of params across all data)
# Per-cluster tuning: make tune-lgbm-clusters (tunes independently per ml_cluster)

tuning:
  n_trials: 50                        # Optuna trials for global tuning (more = better but slower)
  n_splits: 5                         # Walk-forward CV folds
  gap_months: 2                       # Gap between train and validation in each fold (causal)
  val_months_per_fold: 3              # Validation window size per fold
  min_train_months: 13                # Min training months required before first fold
  early_stopping_rounds: 50           # Early stopping rounds within each trial
  n_estimators_max: 2000              # Max boosting rounds per trial
  n_estimators_buffer: 1.1            # Buffer multiplier for final n_estimators (1.1 = 10% more than best trial)
  random_seed: 42
  output_dir: data/tuning
  search_space_ref: hyperparameter_tuning.yaml  # File defining Optuna search bounds


# ─── CHAMPION SELECTION ───────────────────────────────────────────────────────
# Selects the best forecasting model per DFU (or per cluster) from backtest results.
# The "champion" model's predictions are loaded into fact_external_forecast_monthly
# with model_id='champion' for downstream consumption (inventory planning, S&OP).

champion:
  strategy: ensemble                  # Selection strategy. Options:
                                      #   "expanding"           — per-DFU expanding window WAPE (classic)
                                      #   "per_cluster"         — best model per ml_cluster applied to all DFUs
                                      #   "ensemble"            — blended forecast from top-K models
                                      #   "adaptive_ensemble"   — inverse-WAPE weighted blend
                                      #   "bayesian_model_avg"  — Bayesian model averaging
                                      #   "meta_learner"        — random forest picks model per DFU
                                      #   "regime_adaptive"     — adapts to demand regime changes
                                      #   "optimized_decay"     — exponentially decays older performance
  strategy_params:
    top_k: 2                          # For ensemble strategies: blend top K models
    weight_method: equal              # "equal", "inverse_wape", "softmax"
    min_prior_months: 3               # Min causal prior months before a model can be selected
  fallback_model_id: seasonal_naive   # Model used when champion has no prediction for a DFU-month
  metric: accuracy_pct                # Metric for ranking models: "accuracy_pct" or "wape"
  lag: execution                      # Which lag to evaluate: "execution" (natural lag) or 0-4 (fixed lag)
  min_sku_rows: 3                     # Min DFU-months required per model to qualify
  min_dfu_rows: 3                     # Min months per DFU to include in selection
  champion_model_id: champion         # model_id written to forecast table for champion rows
  meta_learner:                       # Config for meta_learner strategy
    model_type: random_forest
    n_estimators: 200
    max_depth: 15
    test_months: 3                    # Holdout months for meta-learner evaluation
    performance_window: 6             # Months of performance history as meta-learner features
  models:                             # Models competing for champion (must have backtest results loaded)
  - lgbm_cluster
  - nbeats
  - nhits
  - seasonal_naive
  - chronos_bolt
  - chronos2_enriched
  - mstl


# ─── PRODUCTION FORECAST ──────────────────────────────────────────────────────
# Generates forward-looking forecasts using champion (or specified) model artifacts.
# Output goes to fact_production_forecast table.

production_forecast:
  horizon_months: 24                  # How many months ahead to forecast
  lookback_months: 36                 # Months of history to feed the model
  min_history_months: 12              # DFUs with fewer months use cold_start_model_id instead
  cold_start_model_id: rolling_mean   # Model for DFUs with 3-12 months of history
  cold_start_min_months: 3            # DFUs with fewer than this are skipped entirely
  fallback_model_id: lgbm_cluster     # Default model when champion artifact is missing
  recursive: true                     # Use recursive multi-step prediction
  plan_version_format: '%Y-%m'        # Version label format (e.g., "2026-03")
  keep_last_n_versions: 3             # Keep N most recent plan versions, archive older ones
  confidence_interval:
    enabled: true                     # Generate prediction intervals
    source_model_ids:                 # Models whose residuals are used for interval estimation
    - lgbm_cluster
    - catboost_cluster
    - xgboost_cluster
    residual_lag: 0                   # Which backtest lag to use for residual computation
    min_residual_months: 6            # Min months of residuals required
    z_lower: 1.282                    # Z-score for lower bound (1.282 = 10th percentile)
    z_upper: 1.282                    # Z-score for upper bound (1.282 = 90th percentile)
    horizon_scaling: sqrt             # How uncertainty grows with horizon: "sqrt" or "linear"
    sigma_floor: 1.0                  # Min residual std (prevents zero-width intervals)
    sigma_cap_multiplier: 3.0         # Max std = multiplier × median std across DFUs
  model_registry:
    base_path: data/models            # Where .pkl model artifacts are stored
  scheduler:
    job_type: generate_production_forecast
    cron: "0 6 2 * *"                 # Run on 2nd of every month at 6 AM


# ─── RUN TRACKING ─────────────────────────────────────────────────────────────
# Tracks backtest runs and tuning experiments for comparison and governance.

tracking:
  backup_dir: data/backtest/tuning_archive
  auto_register: true                 # Automatically register new runs
  auto_compare_to_latest: true        # Compare new run to latest promoted run
  improvement_threshold_bps: 5        # Min improvement (basis points) to flag as "improved"
  verdicts:
    improved_min_delta_accuracy: 0.05   # Accuracy delta to label as "improved"
    degraded_max_delta_accuracy: -0.05  # Accuracy delta to label as "degraded"
  max_archive_runs: 50                # Max archived runs before oldest are pruned


# ─── CLUSTERING ───────────────────────────────────────────────────────────────
# Segments DFUs into demand-pattern clusters. Clusters are used for:
# - Per-cluster model training (one model per cluster)
# - Per-cluster hyperparameter profiles (cluster_tuning_profiles.yaml)
# - Inventory planning segmentation

clustering:
  enabled: true                       # Master switch — false disables all clustering
  cluster_sizing:
    samples_per_feature: 1            # Min rows per feature for training viability
  config_ref: null                    # Clustering params come from cluster_experiment table (promoted row)
  tuning_profiles_ref: cluster_tuning_profiles.yaml  # Per-cluster hyperparameter overrides
  experiment_templates_ref: cluster_experiment_templates.yaml
  steps:
    generate_features: true
    train_model: true
    label_clusters: true
    update_db: true                   # Write cluster labels to dim_sku.ml_cluster
  artifacts:
    features_csv: data/clustering_features.csv
    output_dir: data/clustering
  db_target:
    table: dim_sku
    column: ml_cluster                # Column updated with cluster labels


# ─── BACKTEST SAMPLING ────────────────────────────────────────────────────────
# For large datasets, sample DFUs to speed up backtesting while maintaining
# statistical representativeness across clusters.

backtest_sampling:
  enabled: true
  default_target_n: 5000              # Target number of DFUs to sample
  default_method: proportional        # "proportional" (cluster-weighted) or "equal" (same per cluster)
  min_per_cluster: 10                 # Min DFUs per cluster even if proportional allocation is lower
  max_target_n: 20000                 # Safety cap
  seed: 42
  representativeness_threshold: 0.05  # Max allowed distribution shift between sample and population


# ─── PIPELINE ORCHESTRATION ───────────────────────────────────────────────────
# Defines the end-to-end pipeline stages and their dependencies.
# Used by make setup-all and the pipeline status dashboard.

pipeline:
  stages:
  - name: clustering
    description: Segment DFUs into demand-pattern clusters
    makefile_target: cluster-all
    depends_on: []
    enabled_by: clustering.enabled
  - name: backtest
    description: Expanding-window backtest for all enabled algorithms
    makefile_target: backtest-all
    depends_on:
    - clustering
    enabled_by: always
  - name: load
    description: Load backtest predictions into Postgres
    makefile_target: backtest-load-all-bulk
    depends_on:
    - backtest
    enabled_by: always
  - name: champion
    description: Select best model per DFU from backtest results
    makefile_target: champion-all
    depends_on:
    - load
    enabled_by: always
  - name: forecast
    description: Generate production forecasts using champion models
    makefile_target: forecast-generate
    depends_on:
    - champion
    enabled_by: always
  auxiliary:
  - name: seasonality
    description: Detect per-DFU seasonality profiles
    makefile_target: seasonality-all
  - name: variability
    description: Compute per-DFU demand variability class
    makefile_target: variability-all
