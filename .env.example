# Supply Chain Command Center — Environment Variables
# Copy to .env and fill in real values: cp .env.example .env
# NEVER commit .env with real credentials!

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5440
POSTGRES_DB=demand_mvp
POSTGRES_USER=demand
POSTGRES_PASSWORD=changeme

# --- Service Ports ---
POSTGRES_HOST_PORT=5440
MLFLOW_HOST_PORT=5003
REDIS_HOST_PORT=6379

# --- Redis (cache + single-flight stampede protection) ---
# When set, the API uses Redis as a shared cache across gunicorn workers.
# When unset/unreachable, the cache layer falls back to per-process in-memory.
# In docker-compose this is overridden to redis://redis:6379/0 by the api service.
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
# REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
API_KEY=

# --- OpenAI (for AI features) ---
OPENAI_API_KEY=your-openai-api-key-here

# --- Google (for market intelligence) ---
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CX=your-google-cse-id-here

# --- Optional ---
# PLANNING_DATE=2025-01-01      # Override planning date (default: system date)
# USE_SYSTEM_DATE=true           # Use system date instead of config
# DEMAND_GPU=auto                # GPU acceleration: on/off/auto
# MLFLOW_TRACKING_URI=http://localhost:5001
